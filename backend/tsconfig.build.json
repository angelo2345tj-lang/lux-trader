{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "..",
    "outDir": "./dist",
    "baseUrl": "..",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/**/*",
    "../services/**/*",
    "../engines/**/*",
    "../types/**/*",
    "../utils/**/*",
    "../constants.ts",
    "../types.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*.spec.ts"
  ]
}